# =============================================
# VARIABLES DE ENTORNO - HackChat App
# Copia este archivo como .env y completa los valores
# =============================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=hackchat_db

# Sesiones Express
SESSION_SECRET=cambia_esto_por_un_string_largo_y_aleatorio

# Google OAuth 2.0
# Obtener en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Render (solo en producción)
# RENDER=true
