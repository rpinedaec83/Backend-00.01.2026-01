{
  "info": {
    "name": "Mini-Learning Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST /users",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"passwordHash\": \"x\",\n  \"role\": \"instructor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "GET /users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?role=student&q=ada&page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "role", "value": "student" },
                { "key": "q", "value": "ada" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "POST /courses",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Intro a Node\",\n  \"description\": \"Curso base\",\n  \"ownerId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "GET /courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/courses?published=true&q=node&order=createdAt:DESC&page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["courses"],
              "query": [
                { "key": "published", "value": "true" },
                { "key": "q", "value": "node" },
                { "key": "order", "value": "createdAt:DESC" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET /courses/:slug",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/courses/intro-a-node",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "intro-a-node"]
            }
          }
        },
        {
          "name": "PUT /courses/:id",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"published\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses/1",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1"]
            }
          }
        },
        {
          "name": "DELETE /courses/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/courses/1",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Lessons",
      "item": [
        {
          "name": "POST /courses/:courseId/lessons",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Setup\",\n  \"body\": \"Contenido minimo de 20 caracteres.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses/1/lessons",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1", "lessons"]
            }
          }
        },
        {
          "name": "GET /courses/:courseId/lessons",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/courses/1/lessons?order=ASC",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1", "lessons"],
              "query": [{ "key": "order", "value": "ASC" }]
            }
          }
        },
        {
          "name": "PUT /lessons/:id",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Setup actualizado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/lessons/1",
              "host": ["{{baseUrl}}"],
              "path": ["lessons", "1"]
            }
          }
        },
        {
          "name": "DELETE /lessons/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/lessons/1",
              "host": ["{{baseUrl}}"],
              "path": ["lessons", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "POST /courses/:courseId/enroll",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses/1/enroll",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1", "enroll"]
            }
          }
        },
        {
          "name": "PATCH /enrollments/:id/status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"score\": 95\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enrollments/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["enrollments", "1", "status"]
            }
          }
        },
        {
          "name": "GET /courses/:courseId/enrollments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/courses/1/enrollments?status=active",
              "host": ["{{baseUrl}}"],
              "path": ["courses", "1", "enrollments"],
              "query": [{ "key": "status", "value": "active" }]
            }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "POST /lessons/:lessonId/comments",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"body\": \"Buen contenido, gracias.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/lessons/1/comments",
              "host": ["{{baseUrl}}"],
              "path": ["lessons", "1", "comments"]
            }
          }
        },
        {
          "name": "GET /lessons/:lessonId/comments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lessons/1/comments?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["lessons", "1", "comments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
